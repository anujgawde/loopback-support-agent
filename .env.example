# ── LLM Provider ────────────────────────────
LLM_PROVIDER=gemini                    # gemini | claude | openai
GEMINI_API_KEY=                        # Get from https://aistudio.google.com/apikey
# ANTHROPIC_API_KEY=                   # Only if LLM_PROVIDER=claude
# OPENAI_API_KEY=                      # Only if LLM_PROVIDER=openai

# ── Notion ──────────────────────────────────
NOTION_API_KEY=                        # From https://www.notion.so/my-integrations
NOTION_KB_DATABASE_ID=                 # Database ID from Notion URL

# ── Qdrant ──────────────────────────────────
QDRANT_URL=                            # Qdrant Cloud URL or http://localhost:6333
QDRANT_API_KEY=                        # Qdrant Cloud API key (blank for local Docker)
QDRANT_COLLECTION=support-kb

# ── App ─────────────────────────────────────
COMPANY_NAME=YourCompany               # Used in seed data, UI, and prompts
PORT=3000
FRONTEND_URL=http://localhost:3001     # For CORS
